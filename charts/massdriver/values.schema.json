{
  "type": "object",
  "required": ["dockerhub", "domain", "licenseKey", "postgres", "smtp"],
  "properties": {
    "dockerhub": {
      "type": "object",
      "description": "Docker Hub credentials for pulling images",
      "required": ["username", "accessToken"],
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1
        },
        "accessToken": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "description": "The domain for your Massdriver deployment, e.g., 'massdriver.cloud'"
    },
    "licenseKey": {
      "type": "string",
      "minLength": 1,
      "description": "The license key for your Massdriver deployment"
    },
    "oidc": {
      "type": "array",
      "description": "OpenID Connect configurations for authentication",
      "items": {
        "type": "object",
        "required": ["provider", "authorizeUrl", "tokenUrl", "clientId", "clientSecret"],
        "properties": {
          "provider": {
            "type": "string",
            "description": "The name of the OIDC provider",
            "enum": ["github", "google", "microsoft", "okta"]
          },
          "authorizeUrl": {
            "type": "string",
            "minLength": 1,
            "description": "The authorization URL for the OIDC provider"
          },
          "tokenUrl": {
            "type": "string",
            "minLength": 1,
            "description": "The token URL for the OIDC provider"
          },
          "clientId": {
            "type": "string",
            "minLength": 1,
            "description": "The client ID for the OIDC provider"
          },
          "clientSecret": {
            "type": "string",
            "minLength": 1,
            "description": "The client secret for the OIDC provider"
          },
          "autojoinOrganization": {
            "type": "string",
            "description": "The Massdriver organization to autojoin after OIDC authentication (optional)"
          },
          "uiLabel": {
            "type": "string",
            "description": "The label to show on the button in the Massdriver UI for this OIDC provider (optional)"
          },
          "uiIconUrl": {
            "type": "string",
            "description": "The URL of an icon to show on the button in the Massdriver UI for this OIDC provider (optional)"
          },
          "okta": {
            "type": "object",
            "description": "Okta-specific configuration (required when provider is 'okta')",
            "required": ["site"],
            "properties": {
              "site": {
                "type": "string",
                "minLength": 1,
                "description": "The Okta organization URL, e.g., 'https://your-org.okta.com'"
              },
              "authorizationServerId": {
                "type": "string",
                "description": "The Okta authorization server ID (optional, omit to use global /oauth2/v1/... endpoints)"
              },
              "userinfoUrl": {
                "type": "string",
                "description": "Custom userinfo endpoint URL (optional, auto-derived from site and authorizationServerId)"
              }
            }
          }
        },
        "if": {
          "required": ["provider"],
          "properties": {
            "provider": { "const": "okta" }
          }
        },
        "then": {
          "required": ["okta"]
        }
      }
    },
    "postgres": {
      "type": "object",
      "description": "PostgreSQL database configuration",
      "required": ["username", "password", "hostname", "database", "port"],
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1
        },
        "password": {
          "type": "string",
          "minLength": 1
        },
        "hostname": {
          "type": "string",
          "minLength": 1
        },
        "database": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "smtp": {
      "type": "object",
      "description": "SMTP server configuration for sending emails",
      "required": ["server", "port", "username", "password", "fromAddress"],
      "properties": {
        "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
        },
        "server": {
          "type": "string",
          "minLength": 1
        },
        "username": {
          "type": "string",
          "minLength": 1
        },
        "password": {
          "type": "string",
          "minLength": 1
        },
        "fromAddress": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}